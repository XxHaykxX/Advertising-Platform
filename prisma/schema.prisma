// Prisma schema — Advertising Platform
// Datasource: MySQL on Hostinger (architecture.md ADR-002).
// Conventions: cuid() PKs, explicit @db.Text for long fields, explicit onDelete on FKs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// === ENUMS ===

enum UserRole {
  ADVERTISER
  PUBLISHER
  ADMIN
}

enum AdminSubrole {
  OWNER
  MANAGER
  BROKER
  SUPPORT
}

enum CompanyVerifStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_INFO
}

enum NotificationType {
  INQUIRY_MESSAGE
  INQUIRY_STATUS
  VERIFICATION_RESULT
  LISTING_DECISION
  ADMIN_ASSIGN
  ADMIN_SLA_BREACH
}

enum ChannelType {
  PRODUCT_PLACEMENT
  IN_VIDEO_AD
  WEBSITE_BANNER
  TV
  RADIO
  OUTDOOR
  SOCIAL
  PODCAST
  PRINT
  INFLUENCER
  EVENT
}

// === CORE (stubs for S-01.1; expanded in subsequent stories) ===

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  emailVerified    DateTime?
  passwordHash     String
  name             String
  phone            String?
  role             UserRole
  adminSubrole     AdminSubrole?
  companyId        String?
  company          Company?      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  twoFactorEnabled Boolean       @default(false)
  twoFactorSecret  String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  lastLoginAt      DateTime?

  notifications       Notification[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([role])
}

model VerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?          @db.Text
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

model Company {
  id                 String             @id @default(cuid())
  name               String
  legalName          String?
  taxId              String?
  type               String?
  foundingYear       Int?
  country            String             @default("AM")
  address            String?            @db.Text
  logoUrl            String?
  // For advertisers: ChannelType[] (interest). For publishers: not used —
  // owned channels live in SourceChannel.ownerCompanyId.
  channelsOfInterest Json?
  verificationStatus CompanyVerifStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedById       String?
  canAdvertise       Boolean            @default(false)
  canPublish         Boolean            @default(false)
  users              User[]
  industries         CompanyIndustry[]
  sourceChannels     SourceChannel[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([verificationStatus])
}

model Industry {
  id        String            @id @default(cuid())
  name      String            @unique
  parentId  String?
  parent    Industry?         @relation("IndustryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Industry[]        @relation("IndustryHierarchy")
  archived  Boolean           @default(false)
  companies CompanyIndustry[]
}

model CompanyIndustry {
  companyId  String
  industryId String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([companyId, industryId])
}

model SourceChannel {
  id             String      @id @default(cuid())
  name           String
  type           ChannelType
  ownerCompanyId String?
  ownerCompany   Company?    @relation(fields: [ownerCompanyId], references: [id], onDelete: SetNull)
  archived       Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@index([type])
  @@index([ownerCompanyId])
}
