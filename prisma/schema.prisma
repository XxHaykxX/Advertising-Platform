generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Setting {
  key   String @id
  value String
}

enum Role {
  SUPERADMIN
  PUBLISHER
  MODERATOR
  BRAND
  CREATOR
}

/// Moderation lifecycle for creator-submitted projects.
enum ModerationStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ProjectKind {
  FILM
  SERIAL
}

/// Self-serve member (BRAND / CREATOR) approval lifecycle. Staff users
/// (SUPERADMIN / PUBLISHER) are seeded as APPROVED and ignore this gate.
enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String?
  googleId     String?       @unique
  role         Role          @default(PUBLISHER)
  status       AccountStatus @default(APPROVED)
  name         String
  company      String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  avatar       String? // URL or data-URL avatar; falls back to initials from `name`

  // ── BRAND-only profile fields (#23) — nullable so existing rows (staff +
  // CREATOR members) stay valid without a backfill ──
  website         String? // brand's homepage URL
  brandCategories String? @db.Text // JSON string[] — see src/lib/brand-categories.ts
  budgetRange     String? // one of BUDGET_RANGES in src/lib/brand-categories.ts

  projects  Project[]
  interests Interest[] // Interest rows this user (as a BRAND) has expressed
  passwordResetTokens PasswordResetToken[]
  notifications Notification[]
}

/// In-app notification (#25 / V9). Text is NOT stored translated — only a
/// `type` + a small JSON `data` payload; the UI renders localized copy in the
/// viewer's current locale (see src/lib/notifications.ts). `link` is an
/// in-app href the row navigates to when clicked.
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int // recipient
  type      String // INTEREST | PROJECT_SUBMITTED | PROJECT_APPROVED | PROJECT_REJECTED
  data      String?  @db.Text // JSON payload: { projectTitle, brandName, projectId, … }; MySQL forbids TEXT defaults, so nullable — code treats null as "{}"
  link      String   @default("") // in-app href, e.g. "/reports/12" or "/admin/moderation"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

/// One-time password-reset tokens (email flow, #forgot-password). Only a
/// SHA-256 hash of the token is stored; the raw token lives solely in the
/// emailed link. A token is valid while usedAt IS NULL and expiresAt is in the
/// future. Old rows are left in place (not deleted on a new request) and simply
/// fail the validity check once expired/used.
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// UI translation strings (ru/en/hy) — interface i18n only
model Content {
  key String @id
  ru  String @db.Text
  en  String @db.Text
  hy  String @db.Text
}

enum ProjectStatus {
  PRE_PRODUCTION
  FILMING
  POST_PRODUCTION
  RELEASED
}

/// A film/series project listed for product placement
model Project {
  id             Int           @id @default(autoincrement())
  code           String        @unique // "#PP-2026-8540"
  title          String
  titleHy        String        @default("")
  titleRu        String        @default("")
  titleEn        String        @default("")
  genre          String
  synopsis       String        @db.Text
  synopsisHy     String?       @db.Text
  synopsisRu     String?       @db.Text
  synopsisEn     String?       @db.Text
  poster         String?
  gallery        String?       @db.Text // JSON string[]; nullable — MySQL forbids literal defaults on TEXT columns
  format         String        @default("") // "50 ep × 1m 15s"
  studio         String        @default("")
  status         ProjectStatus @default(PRE_PRODUCTION)
  releaseLabel   String        @default("") // "Q1 2027"
  countries      String        @default("") // "US, UK, …"
  audienceGender String        @default("All") // All | Male | Female
  audienceAge    String        @default("") // "16-30"
  ageRating      String        @default("") // content rating badge on the poster: "16+", "18+", "12+", …
  projViews      String        @default("") // "2.4M"
  // Money — admin enters AMD only; the public site converts + formats for
  // display in the visitor's chosen currency (see src/lib/currency). All
  // nullable: budget/CPM are context, placement price is optional (null ->
  // "on request").
  budgetMinAmd   Int?
  budgetMaxAmd   Int?
  cpmMinAmd      Int?
  cpmMaxAmd      Int?
  priceMinAmd    Int?
  priceMaxAmd    Int?
  isActive       Boolean       @default(true)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  ownerId        Int

  // ── Moderation & content-kind (added for the Creator submission flow) ──
  moderationStatus ModerationStatus @default(APPROVED) // existing rows stay visible; the creator flow will set PENDING
  kind             ProjectKind      @default(FILM)
  episodes         Int? // episode count, for SERIAL
  episodeMinutes   Int? // per-episode runtime, for SERIAL
  genres           String?          @db.Text // JSON string[] multi-genre; nullable, same pattern as platforms/cinemas — `genre` above stays as the primary display value
  formatCategory   String           @default("") // marketing format bucket (FEATURE|SERIES|SITCOM|…), separate from `kind`; drives the catalog Format filter
  language         String           @default("") // primary language (Armenian|Russian|English|…); drives the catalog Language filter

  applicationDeadline DateTime?
  releaseDate         DateTime?
  platforms           String?   @db.Text // JSON string[]; nullable — MySQL forbids literal defaults on TEXT columns
  placementType       String? // "In-Frame" | "Story Integration" | "Mention"
  priceNote           String?

  // ── Real press-kit fields (added for the Aram title, 2026-07-09) ──
  tagline   String? // one-line logline, shown in the report hero
  subgenre  String? // e.g. "Musical" — narrower than `genre`
  references String? @db.Text // comparable titles ("Bohemian Rhapsody, Ray"), comma/JSON list
  cinemas    String? @db.Text // exhibition venues ("Cinema Star, Kino Park"), comma/JSON list

  owner         User                   @relation(fields: [ownerId], references: [id])
  actors        Actor[]
  tiers         SponsorshipTier[]
  interests     Interest[]

  @@index([ownerId])
}

/// A person attached to a project (cast or crew), shown in the pitch materials
model Actor {
  id        Int    @id @default(autoincrement())
  projectId Int
  name      String
  role      String
  kind      String @default("CAST") // CAST | CREW — press-kits often list crew, not cast
  photo     String? // uploaded headshot path ("/uploads/…"); null -> initials avatar
  sortOrder Int    @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// A sponsorship package/tier for a project (the core monetization offer):
/// a named price point with a list of included benefits. Distinct from
/// scene-level PlacementOpportunity — tiers are the productised sponsor deal.
model SponsorshipTier {
  id        Int     @id @default(autoincrement())
  projectId Int
  name      String // "Official Sponsor" | "General Sponsor" (+ per-locale later)
  priceAmd  Int // 20000000 / 30000000 / 40000000
  benefits  String  @db.Text // JSON string[] — the included-benefits bullet list
  sortOrder Int     @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// A past placement case study shown in the portfolio/case-studies section
model Portfolio {
  id          Int      @id @default(autoincrement())
  title       String
  brand       String
  description String   @db.Text
  image       String?
  metrics     String?  @db.Text // JSON object, e.g. {"views":"2.1M","recall":"+38%"}
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

/// A studio/platform partner logo shown in the trust/partners strip
model Partner {
  id        Int     @id @default(autoincrement())
  name      String
  logo      String?
  url       String?
  sortOrder Int     @default(0)
}

/// Lead applications (Express Interest + contact form)
model Application {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?
  phone        String?
  company      String?
  projectId    Int?
  projectTitle String?
  budget       String?
  message      String?  @db.Text
  status       String   @default("new") // new | in_progress | closed
  note         String?  @db.Text
  createdAt    DateTime @default(now())
}

/// BRAND member's "Express Interest" on a project (#23 — brand cabinet).
/// Distinct from Application: Interest is a lightweight, per-user signal tied
/// to an authenticated BRAND account (drives /account/brand/interests),
/// while Application is the anonymous lead-capture form. MUTUAL is reserved
/// for a future two-sided reveal (creator also expresses interest back) —
/// not set anywhere yet (TODO, see #23 report).
enum InterestStatus {
  SENT
  MUTUAL
  DECLINED
}

model Interest {
  id        Int             @id @default(autoincrement())
  brandId   Int
  projectId Int
  status    InterestStatus  @default(SENT)
  createdAt DateTime        @default(now())

  brand   User    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([brandId, projectId])
  @@index([projectId])
}
