// Prisma schema — Advertising Platform (MVP)
// Dev + Prod: MySQL 8. Dev runs the `adplatform-mysql` Docker container (port 3307).
// Multilingual fields are stored per-language (_ru / _en / _hy).

generator client {
  provider = "prisma-client-js"
  // native = local/CI build platform; debian targets = Hostinger runtime
  // (glibc, openssl 1.1.x / 3.0.x). Ensures the Linux query engine ships.
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Key/value app settings (admin password hash, contacts, socials, default lang)
model Setting {
  key   String @id
  value String
}

/// Editable landing texts, one row per content key, three languages
model Content {
  key String @id
  ru  String @db.Text
  en  String @db.Text
  hy  String @db.Text
}

/// Projects / films available for product placement
model Project {
  id              Int       @id @default(autoincrement())
  titleRu         String
  titleEn         String    @default("")
  titleHy         String    @default("")
  genreRu         String    @default("")
  genreEn         String    @default("")
  genreHy         String    @default("")
  descriptionRu   String    @db.Text
  descriptionEn   String    @db.Text
  descriptionHy   String    @db.Text
  placementTypeRu String    @default("")
  placementTypeEn String    @default("")
  placementTypeHy String    @default("")
  poster          String?
  gallery         String    @default("[]") @db.VarChar(2048) // JSON array of image paths
  price           String?
  currency        String?
  slotsTotal      Int       @default(0)
  slotsAvailable  Int       @default(0)
  releaseDate     DateTime?
  platforms       String    @default("[]") @db.VarChar(2048) // JSON array of strings
  bookingDeadline DateTime?
  sortOrder       Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  actors Actor[]
  scenes Scene[]
}

/// Cast member shown on a project's detail page
model Actor {
  id          Int     @id @default(autoincrement())
  projectId   Int
  firstName   String
  firstNameEn String  @default("")
  firstNameHy String  @default("")
  lastName    String
  lastNameEn  String  @default("")
  lastNameHy  String  @default("")
  role        String  @default("")
  roleEn      String  @default("")
  roleHy      String  @default("")
  photo       String?
  sortOrder   Int     @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// A scene where a brand placement is possible (project detail page)
model Scene {
  id            Int    @id @default(autoincrement())
  projectId     Int
  title         String
  titleEn       String @default("")
  titleHy       String @default("")
  description   String @db.Text
  descriptionEn String @db.Text
  descriptionHy String @db.Text
  placement     String @db.Text
  placementEn   String @db.Text
  placementHy   String @db.Text
  sortOrder     Int    @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

/// Portfolio cases (where ads were already placed)
model Portfolio {
  id            Int      @id @default(autoincrement())
  titleRu       String
  titleEn       String   @default("")
  titleHy       String   @default("")
  descriptionRu String   @db.Text
  descriptionEn String   @db.Text
  descriptionHy String   @db.Text
  images        String   @default("[]") @db.VarChar(2048) // JSON array of image paths
  videoType     String   @default("youtube") // "youtube" | "file"
  videoUrl      String?
  videoFile     String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
}

/// Partner logos for the marquee
model Partner {
  id        Int    @id @default(autoincrement())
  name      String
  logo      String?
  url       String?
  sortOrder Int    @default(0)
}

/// Lead applications submitted via the contact form
model Application {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String
  email        String?
  company      String?
  projectId    Int?
  projectTitle String?
  budget       String?
  message      String?  @db.Text
  consent      Boolean  @default(false)
  status       String   @default("new") // new | in_progress | closed
  note         String?  @db.Text
  createdAt    DateTime @default(now())
}
