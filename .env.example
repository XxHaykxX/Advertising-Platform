# ─────────────────────────────────────────────────────────────────
# Advertising Platform — environment variables
# Copy to .env (gitignored) and fill values for local dev.
# Production values are set in Hostinger panel → Node.js app → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# Database (Hostinger MySQL — see architecture.md §10.2)
DATABASE_URL="mysql://USER:PASS@127.0.0.1:3306/DBNAME"

# NextAuth.js (Auth.js v5)
NEXTAUTH_URL="http://localhost:3000"
# Generate via: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Admin TOTP encryption (for twoFactorSecret in DB)
# Generate via: openssl rand -base64 32
TWOFACTOR_ENCRYPTION_KEY=""

# Dev-only escape hatch for the admin 2FA gate. Set to "true" to skip TOTP
# enrolment + verification on /admin/*. Ignored when NODE_ENV=production.
# Default: unset (2FA enforced).
# DISABLE_ADMIN_2FA="true"

# Email — Resend (free tier 3000 msg/mo)
RESEND_API_KEY=""
EMAIL_FROM="noreply@advertising-platform.am"

# Error monitoring — Sentry (free tier 5000 events/mo)
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Analytics — PostHog (free tier 1M events/mo)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# Chat provider — TBD (S-07.1)
# CHAT_PROVIDER_API_KEY=""
# CHAT_PROVIDER_API_SECRET=""
# CHAT_PROVIDER_WEBHOOK_SECRET=""
# NEXT_PUBLIC_CHAT_PROVIDER_KEY=""
